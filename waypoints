-- Sync settings UI to current settings (call when opening panel)
local function syncSettingsUI()
	settingsControls.size( ({S=1,M=2,L=3})[settings.markerSize] )
	settingsControls.shape( ({Cylinder=1,Sphere=2,Block=3})[settings.markerShape] )
	local opIdx = settings.markerTransparency <= 0.25 and 1 or settings.markerTransparency <= 0.5 and 2 or 3
	settingsControls.opacity(opIdx)
	settingsControls.labels(settings.showLabels and 1 or 2)
	settingsControls.sort( ({ORDER=1,DIST=2,NAME=3})[settings.sortMode] )
	settingsControls.units(settings.distUnit == "Studs" and 1 or 2)
	settingsControls.distMode(settings.distMode == "3D" and 1 or 2)
	settingsControls.tpLift( ({[3]=1,[5]=2,[8]=3})[settings.tpHeight] )
	settingsControls.tpStyle(settings.smoothTp and 2 or 1)
	settingsControls.beam(settings.showBeam and 2 or 1)
	settingsControls.maxWp( ({[0]=1,[5]=2,[10]=3,[20]=4})[settings.maxWaypoints] )
	settingsControls.uiScale( ({[0.8]=1,[1]=2,[1.2]=3})[settings.uiScale] )
	for i, cb in ipairs(colorBtns) do
		cb.stroke.Color = (i == settings.markerColorIdx) and Color3.new(1,1,1) or Color3.fromRGB(80,80,80)
	end
end

