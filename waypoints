local function titleGradient(parent)
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(90, 130, 210)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(30,  65, 145)),
	})
	g.Rotation = 90
	g.Parent   = parent
end

local function formatDist(studs)
	if settings.distUnit == "Metres" then
		return string.format("%.0fm", studs * 0.28)
	end
	return studs .. "st"
end

local function getHorizontalDist(a, b)
	local dx = a.X - b.X
	local dz = a.Z - b.Z
	return math.sqrt(dx*dx + dz*dz)
end

local function getDistToPlayer(pos)
	if settings.distMode == "Horizontal" then
		return getHorizontalDist(rootPart.Position, pos)
	end
	return (rootPart.Position - pos).Magnitude
end

local function retroHover(btn, baseColor)
	btn.MouseEnter:Connect(function()
		btn.BackgroundColor3 = Color3.new(
			math.min(baseColor.R + 0.12, 1),
			math.min(baseColor.G + 0.12, 1),
			math.min(baseColor.B + 0.12, 1))
	end)
	btn.MouseLeave:Connect(function()
		btn.BackgroundColor3 = baseColor
	end)
	btn.MouseButton1Down:Connect(function()
		btn.BackgroundColor3 = Color3.new(
			math.max(baseColor.R - 0.1, 0),
			math.max(baseColor.G - 0.1, 0),
			math.max(baseColor.B - 0.1, 0))
	end)
	btn.MouseButton1Up:Connect(function()
		btn.BackgroundColor3 = baseColor
	end)
end

