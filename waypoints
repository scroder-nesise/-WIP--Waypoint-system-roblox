local function createRetroButton(text, faceColor)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0, 64, 1, 0)
	btn.BackgroundColor3 = faceColor
	btn.Text = text
	btn.TextColor3 = Color3.new(1, 1, 1)
	btn.TextScaled = true
	btn.Font = Enum.Font.Legacy
	btn.BorderSizePixel = 0
	btn.AutoButtonColor = false
	btn.Parent = buttonsFrame

	-- raised bevel
	applyRaisedBorder(btn)

	-- hover / press feedback
	btn.MouseEnter:Connect(function()
		btn.BackgroundColor3 = Color3.new(
			math.min(faceColor.R + 0.12, 1),
			math.min(faceColor.G + 0.12, 1),
			math.min(faceColor.B + 0.12, 1)
		)
	end)
	btn.MouseLeave:Connect(function()
		btn.BackgroundColor3 = faceColor
	end)
	btn.MouseButton1Down:Connect(function()
		btn.BackgroundColor3 = Color3.new(
			math.max(faceColor.R - 0.1, 0),
			math.max(faceColor.G - 0.1, 0),
			math.max(faceColor.B - 0.1, 0)
		)
	end)
	btn.MouseButton1Up:Connect(function()
		btn.BackgroundColor3 = faceColor
	end)

	return btn
end

