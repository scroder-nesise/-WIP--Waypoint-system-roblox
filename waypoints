-- ================================================================
--  TELEPORT
-- ================================================================
teleportButton.MouseButton1Click:Connect(function()
    if not selectedWaypoint or not rootPart then
        setStatus("Select a waypoint to teleport!")
        return
    end
    rootPart.CFrame = CFrame.new(selectedWaypoint.position + Vector3.new(0, settings.tpHeight, 0))
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
    end
    setStatus("Teleported to: " .. selectedWaypoint.name)
end)

-- ================================================================
--  DELETE
-- ================================================================
deleteButton.MouseButton1Click:Connect(function()
    if not selectedWaypoint then
        setStatus("Select a waypoint to delete!")
        return
    end
    local deletedName = selectedWaypoint.name
    if selectedWaypoint.marker then
        selectedWaypoint.marker:Destroy()
    end
    for i, wp in ipairs(waypoints) do
        if wp == selectedWaypoint then
            table.remove(waypoints, i)
            break
        end
    end
    selectedWaypoint = nil
    setStatus("Deleted: " .. deletedName)
    refreshList()
end)

