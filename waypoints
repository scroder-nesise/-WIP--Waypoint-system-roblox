-- World marker
local function createMarker(wp)
	local part = Instance.new("Part")
	part.Name = "WaypointMarker"
	part.Shape = Enum.PartType.Cylinder
	part.Size = Vector3.new(6, 0.25, 6)
	part.Position = wp.position + Vector3.new(0, 0.15, 0)
	part.Anchored = true
	part.CanCollide = false
	part.Transparency = 0.35
	part.Color = Color3.fromRGB(0, 200, 255)
	part.Parent = workspace

	wp.marker = part

	local billboard = Instance.new("BillboardGui")
	billboard.Adornee = part
	billboard.Size = UDim2.new(0, 240, 0, 50)
	billboard.StudsOffset = Vector3.new(0, 4.5, 0)
	billboard.AlwaysOnTop = true
	billboard.LightInfluence = 0
	billboard.Parent = part

	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(1, 0, 1, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text = wp.name
	lbl.TextColor3 = Color3.new(1, 1, 1)
	lbl.TextStrokeTransparency = 0.3
	lbl.TextScaled = true
	lbl.Font = Enum.Font.GothamBold
	lbl.Parent = billboard
end

-- Refresh list
local function refreshList()
	for _, child in ipairs(listFrame:GetChildren()) do
		if child:IsA("Frame") then child:Destroy() end
	end

	if #waypoints == 0 then
		setStatus("No waypoints. Press ADD to create one.")
		return
	end

	local selName = selectedWaypoint and selectedWaypoint.name or ""
	setStatus(selectedWaypoint and ('Selected: "' .. selName .. '"') or "Click a waypoint to select it.")

	for i, wp in ipairs(waypoints) do
		local isSelected = (wp == selectedWaypoint)

		local row = Instance.new("Frame")
		row.Size = UDim2.new(1, 0, 0, 38)
		row.LayoutOrder = i
		row.BackgroundColor3 = isSelected
			and Color3.fromRGB(25, 35, 140)
			or (i % 2 == 0 and Color3.fromRGB(240, 238, 228) or Color3.fromRGB(255, 255, 255))
		row.BorderSizePixel = 0
		row.Parent = listFrame

		-- Bottom border line
		local divider = Instance.new("Frame")
		divider.Size = UDim2.new(1, 0, 0, 1)
		divider.Position = UDim2.new(0, 0, 1, -1)
		divider.BackgroundColor3 = Color3.fromRGB(180, 175, 155)
		divider.BorderSizePixel = 0
		divider.Parent = row

		-- Name
		local nameLabel = Instance.new("TextLabel")
		nameLabel.Size = UDim2.new(0.55, -8, 1, 0)
		nameLabel.Position = UDim2.new(0, 8, 0, 0)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Text = wp.name
		nameLabel.TextColor3 = isSelected and Color3.new(1,1,1) or Color3.fromRGB(30, 30, 30)
		nameLabel.TextXAlignment = Enum.TextXAlignment.Left
		nameLabel.TextScaled = true
		nameLabel.Font = isSelected and Enum.Font.GothamBold or Enum.Font.Gotham
		nameLabel.Parent = row

		-- Distance
		local distLabel = Instance.new("TextLabel")
		distLabel.Name = "DistanceLabel"
		distLabel.Size = UDim2.new(0.45, -8, 1, 0)
		distLabel.Position = UDim2.new(0.55, 0, 0, 0)
		distLabel.BackgroundTransparency = 1
		distLabel.Text = "— studs"
		distLabel.TextColor3 = isSelected and Color3.fromRGB(200,200,255) or Color3.fromRGB(80, 80, 80)
		distLabel.TextXAlignment = Enum.TextXAlignment.Right
		distLabel.TextScaled = true
		distLabel.Font = Enum.Font.Gotham
		distLabel.Parent = row

		-- Vertical divider between name and distance
		local vDivider = Instance.new("Frame")
		vDivider.Size = UDim2.new(0, 1, 0.7, 0)
		vDivider.Position = UDim2.new(0.55, 0, 0.15, 0)
		vDivider.BackgroundColor3 = isSelected and Color3.fromRGB(80,90,180) or Color3.fromRGB(180, 175, 155)
		vDivider.BorderSizePixel = 0
		vDivider.Parent = row

		-- Click to select
		local clickBtn = Instance.new("TextButton")
		clickBtn.Size = UDim2.new(1, 0, 1, 0)
		clickBtn.BackgroundTransparency = 1
		clickBtn.Text = ""
		clickBtn.Parent = row
		clickBtn.MouseButton1Click:Connect(function()
			selectedWaypoint = wp
			refreshList()
		end)

		wp.guiEntry = row
	end
end

-- Live distance
RunService.Heartbeat:Connect(function()
	if not rootPart then return end
	local playerPos = rootPart.Position
	for _, wp in ipairs(waypoints) do
		if wp.guiEntry then
			local d = wp.guiEntry:FindFirstChild("DistanceLabel")
			if d then
				d.Text = math.floor((playerPos - wp.position).Magnitude + 0.5) .. " studs"
			end
		end
	end
end)

