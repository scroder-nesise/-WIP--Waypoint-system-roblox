local lastDistSort = 0
RunService.Heartbeat:Connect(function()
	if not rootPart then return end
	local playerPos = rootPart.Position

	-- Update distance labels every frame
	for _, wp in ipairs(waypoints) do
		if wp.guiEntry then
			local d = wp.guiEntry:FindFirstChild("DistanceLabel")
			if d then
				local dist = math.floor(getDistToPlayer(wp.position) + 0.5)
				d.Text = formatDist(dist)
			end
		end
	end

	-- Re-sort by distance every 0.5s if needed
	if settings.sortMode == "DIST" then
		local now = tick()
		if now - lastDistSort > 0.5 then
			lastDistSort = now
			refreshList()
		end
	end

	-- Update tracer beam
	updateBeam()
end)

