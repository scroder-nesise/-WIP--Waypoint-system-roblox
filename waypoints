-- Create world marker
local function createMarker(waypointData)
	local part = Instance.new("Part")
	part.Name = "WaypointMarker"
	part.Shape = Enum.PartType.Cylinder
	part.Size = Vector3.new(6, 0.25, 6)
	part.Position = waypointData.position + Vector3.new(0, 0.15, 0)
	part.Anchored = true
	part.CanCollide = false
	part.Transparency = 0.35
	part.Color = Color3.fromRGB(0, 200, 255)
	part.Parent = workspace
	
	waypointData.marker = part
	
	-- Billboard name
	local billboard = Instance.new("BillboardGui")
	billboard.Adornee = part
	billboard.Size = UDim2.new(0, 240, 0, 50)
	billboard.StudsOffset = Vector3.new(0, 4.5, 0)
	billboard.AlwaysOnTop = true
	billboard.LightInfluence = 0
	billboard.Parent = part
	
	local nameLabel = Instance.new("TextLabel")
	nameLabel.Size = UDim2.new(1, 0, 1, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = waypointData.name
	nameLabel.TextColor3 = Color3.new(1, 1, 1)
	nameLabel.TextStrokeTransparency = 0.4
	nameLabel.TextScaled = true
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.Parent = billboard
end

-- Refresh list UI
local function refreshList()
	for _, child in ipairs(listFrame:GetChildren()) do
		if child:IsA("Frame") then child:Destroy() end
	end
	
	for _, wp in ipairs(waypoints) do
		local entry = Instance.new("Frame")
		entry.Size = UDim2.new(1, 0, 0, 46)
		entry.BackgroundColor3 = (wp == selectedWaypoint) and Color3.fromRGB(50, 70, 180) or Color3.fromRGB(38, 38, 48)
		entry.BorderSizePixel = 0
		entry.Parent = listFrame
		
		local entryCorner = Instance.new("UICorner")
		entryCorner.CornerRadius = UDim.new(0, 8)
		entryCorner.Parent = entry
		
		-- Circle icon
		local icon = Instance.new("Frame")
		icon.Size = UDim2.new(0, 32, 0, 32)
		icon.Position = UDim2.new(0, 8, 0.5, -16)
		icon.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
		icon.BorderSizePixel = 0
		icon.Parent = entry
		
		local iconCorner = Instance.new("UICorner")
		iconCorner.CornerRadius = UDim.new(0.5, 0)
		iconCorner.Parent = icon
		
		-- Name
		local nameLabel = Instance.new("TextLabel")
		nameLabel.Size = UDim2.new(0.48, -50, 1, 0)
		nameLabel.Position = UDim2.new(0, 48, 0, 0)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Text = wp.name
		nameLabel.TextColor3 = Color3.new(1, 1, 1)
		nameLabel.TextXAlignment = Enum.TextXAlignment.Left
		nameLabel.TextScaled = true
		nameLabel.Font = Enum.Font.Gotham
		nameLabel.Parent = entry
		
		-- Live distance
		local distLabel = Instance.new("TextLabel")
		distLabel.Name = "DistanceLabel"
		distLabel.Size = UDim2.new(0.45, 0, 1, 0)
		distLabel.Position = UDim2.new(0.55, 0, 0, 0)
		distLabel.BackgroundTransparency = 1
		distLabel.Text = "— studs"
		distLabel.TextColor3 = Color3.fromRGB(180, 180, 190)
		distLabel.TextXAlignment = Enum.TextXAlignment.Right
		distLabel.TextScaled = true
		distLabel.Font = Enum.Font.Gotham
		distLabel.Parent = entry
		
		-- Click to select
		local clickBtn = Instance.new("TextButton")
		clickBtn.Size = UDim2.new(1, 0, 1, 0)
		clickBtn.BackgroundTransparency = 1
		clickBtn.Text = ""
		clickBtn.Parent = entry
		clickBtn.MouseButton1Click:Connect(function()
			selectedWaypoint = wp
			refreshList()
		end)
		
		wp.guiEntry = entry
	end
end

-- Live distance updater
RunService.Heartbeat:Connect(function()
	if not rootPart then return end
	local playerPos = rootPart.Position
	
	for _, wp in ipairs(waypoints) do
		if wp.guiEntry then
			local distLabel = wp.guiEntry:FindFirstChild("DistanceLabel")
			if distLabel then
				local dist = (playerPos - wp.position).Magnitude
				distLabel.Text = math.floor(dist + 0.5) .. " studs"
			end
		end
	end
end)

-- Add waypoint
addButton.MouseButton1Click:Connect(function()
	if not rootPart then return end
	local newPos = rootPart.Position
	local newName = "Waypoint " .. (#waypoints + 1)
	
	local newWP = {
		name = newName,
		position = newPos,
		marker = nil,
		guiEntry = nil
	}
	
	table.insert(waypoints, newWP)
	createMarker(newWP)
	refreshList()
end)

