            setStatus("Renamed to: " .. newName)
            refreshList()
        end
        closeDialog()
    end

    okBtn.MouseButton1Click:Connect(confirmRename)
    cancelBtn.MouseButton1Click:Connect(closeDialog)

    -- BUG FIX: Enter key now fires OK correctly
    textBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then confirmRename() end
    end)

    textBox:CaptureFocus()
