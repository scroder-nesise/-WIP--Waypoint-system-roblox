-- ================================================================
--  3D BORDER SYSTEM  (NEW & FIXED — proper Win95 bevels)
-- ================================================================
local function applyBorder(frame, raised, thickness)
	thickness = thickness or 2
	local lite = raised and C.BORDER_LITE or C.BORDER_DARK
	local dark = raised and C.BORDER_DARK or C.BORDER_LITE
	local z    = frame.ZIndex + 1

	local function strip(name, size, pos, color)
		local s = Instance.new("Frame")
		s.Name = name
		s.Size = size
		s.Position = pos
		s.BackgroundColor3 = color
		s.BorderSizePixel = 0
		s.ZIndex = z
		s.Parent = frame
		return s
	end

	strip("Top",    UDim2.new(1, 0, 0, thickness), UDim2.new(0, 0, 0, 0), lite)
	strip("Left",   UDim2.new(0, thickness, 1, 0), UDim2.new(0, 0, 0, 0), lite)
	strip("Bottom", UDim2.new(1, 0, 0, thickness), UDim2.new(0, 0, 1, -thickness), dark)
	strip("Right",  UDim2.new(0, thickness, 1, 0), UDim2.new(1, -thickness, 0, 0), dark)
end

