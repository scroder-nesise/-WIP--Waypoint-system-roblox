local function createMarker(wpData)
    local part = Instance.new("Part")
    part.Name         = "WaypointMarker"
    part.Shape        = Enum.PartType.Cylinder
    part.Size         = MARKER_SIZES[settings.markerSize]
    part.Position     = wpData.position + Vector3.new(0, 0.15, 0)
    part.Anchored     = true
    part.CanCollide   = false
    part.Transparency = 0.35
    part.Color        = MARKER_COLORS[settings.markerColorIdx].color
    part.Parent       = workspace
    wpData.marker     = part

    local billboard = Instance.new("BillboardGui")
    billboard.Adornee        = part
    billboard.Size           = UDim2.new(0, 240, 0, 50)
    billboard.StudsOffset    = Vector3.new(0, 4.5, 0)
    billboard.AlwaysOnTop    = true
    billboard.LightInfluence = 0
    billboard.Enabled        = settings.showLabels
    billboard.Parent         = part

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size                    = UDim2.new(1, 0, 1, 0)
    nameLabel.BackgroundTransparency  = 1
    nameLabel.Text                    = wpData.name
    nameLabel.TextColor3              = Color3.new(1, 1, 1)
    nameLabel.TextStrokeTransparency  = 0.2
    nameLabel.TextStrokeColor3        = Color3.fromRGB(0, 0, 80)
    nameLabel.TextScaled              = true
    nameLabel.Font                    = Enum.Font.Legacy
    nameLabel.Parent                  = billboard
end

-- Assign the forward-declared refreshList
refreshList = function()
    for _, child in ipairs(listFrame:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    -- Build a sorted copy
    local sorted = {}
    for _, wp in ipairs(waypoints) do table.insert(sorted, wp) end

    if settings.sortMode == "NAME" then
        table.sort(sorted, function(a, b) return a.name < b.name end)
    elseif settings.sortMode == "DIST" and rootPart then
        local pos = rootPart.Position
        table.sort(sorted, function(a, b)
            return (a.position - pos).Magnitude < (b.position - pos).Magnitude
        end)
    end

    for i, wp in ipairs(sorted) do
        local isSel = (wp == selectedWaypoint)
        local isAlt = (i % 2 == 0)

        local entry = Instance.new("Frame")
        entry.Size             = UDim2.new(1, 0, 0, 24)
        entry.BackgroundColor3 = isSel and C.SEL_BG or (isAlt and C.ROW_ALT or C.ROW_NORMAL)
        entry.BorderSizePixel  = 0
        entry.LayoutOrder      = i
        entry.Parent           = listFrame

        local sep = Instance.new("Frame")
        sep.Size             = UDim2.new(1, 0, 0, 1)
        sep.Position         = UDim2.new(0, 0, 1, -1)
        sep.BackgroundColor3 = Color3.fromRGB(210, 205, 195)
        sep.BorderSizePixel  = 0
        sep.Parent           = entry

        local icon = Instance.new("TextLabel")
        icon.Size                = UDim2.new(0, 20, 1, 0)
        icon.Position            = UDim2.new(0, 2, 0, 0)
        icon.BackgroundTransparency = 1
        icon.Text                = "📍"
        icon.TextScaled          = true
        icon.Font                = Enum.Font.Legacy
        icon.Parent              = entry

        local nLbl = Instance.new("TextLabel")
        nLbl.Size               = UDim2.new(0.55, -24, 1, 0)
        nLbl.Position           = UDim2.new(0, 24, 0, 0)
        nLbl.BackgroundTransparency = 1
        nLbl.Text               = wp.name
        nLbl.TextColor3         = isSel and C.SEL_TEXT or C.TEXT_DARK
        nLbl.TextXAlignment     = Enum.TextXAlignment.Left
        nLbl.TextScaled         = true
        nLbl.Font               = Enum.Font.Legacy
        nLbl.Parent             = entry

        local dLbl = Instance.new("TextLabel")
        dLbl.Name               = "DistanceLabel"
        dLbl.Size               = UDim2.new(0.45, -6, 1, 0)
        dLbl.Position           = UDim2.new(0.55, 0, 0, 0)
        dLbl.BackgroundTransparency = 1
        dLbl.Text               = "—"
        dLbl.TextColor3         = isSel and C.SEL_TEXT or C.TEXT_MID
        dLbl.TextXAlignment     = Enum.TextXAlignment.Right
        dLbl.TextScaled         = true
        dLbl.Font               = Enum.Font.Legacy
        dLbl.Parent             = entry

        local clickBtn = Instance.new("TextButton")
        clickBtn.Size               = UDim2.new(1, 0, 1, 0)
        clickBtn.BackgroundTransparency = 1
        clickBtn.Text               = ""
        clickBtn.ZIndex             = 2
        clickBtn.Parent             = entry
        clickBtn.MouseButton1Click:Connect(function()
            selectedWaypoint = wp
            setStatus("Selected: " .. wp.name)
            refreshList()
        end)

        wp.guiEntry = entry
    end

    if #waypoints == 0 then
        setStatus("No waypoints. Press ADD to create one.")
    elseif not selectedWaypoint then
        setStatus(#waypoints .. " waypoint(s). Click one to select.")
    end
end

-- ================================================================
--  LIVE DISTANCE UPDATER
-- ================================================================
RunService.Heartbeat:Connect(function()
    if not rootPart then return end
    local playerPos = rootPart.Position
    for _, wp in ipairs(waypoints) do
        if wp.guiEntry then
            local d = wp.guiEntry:FindFirstChild("DistanceLabel")
            if d then
                local dist = math.floor((playerPos - wp.position).Magnitude + 0.5)
                d.Text = formatDist(dist)
            end
        end
    end
end)

-- ================================================================
--  ADD WAYPOINT
-- ================================================================
addButton.MouseButton1Click:Connect(function()
    if not rootPart then return end
    if settings.maxWaypoints > 0 and #waypoints >= settings.maxWaypoints then
        setStatus("⚠ Limit reached! Max: " .. settings.maxWaypoints)
        return
    end
    local newWP = {
        name     = "Waypoint " .. (#waypoints + 1),
        position = rootPart.Position,
        marker   = nil,
        guiEntry = nil,
    }
    table.insert(waypoints, newWP)
    createMarker(newWP)
    setStatus("Added: " .. newWP.name)
    refreshList()
end)

