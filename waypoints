local beamInst, beamAtt0, beamAtt1

local function updateBeamColor()
	if beamInst then
		beamInst.Color = ColorSequence.new(MARKER_COLORS[settings.markerColorIdx].color)
	end
end

local function updateBeam()
	if not settings.showBeam or not selectedWaypoint or not selectedWaypoint.marker or not rootPart then
		if beamInst then beamInst:Destroy() end
		if beamAtt0 then beamAtt0:Destroy() end
		if beamAtt1 then beamAtt1:Destroy() end
		beamInst, beamAtt0, beamAtt1 = nil, nil, nil
		return
	end
	if not beamInst or not beamInst.Parent then
		beamAtt0 = Instance.new("Attachment")
		beamAtt0.Name = "WPBeam0"
		beamAtt0.Parent = rootPart
		beamAtt1 = Instance.new("Attachment")
		beamAtt1.Name = "WPBeam1"
		beamAtt1.Parent = selectedWaypoint.marker
		beamInst = Instance.new("Beam")
		beamInst.Color = ColorSequence.new(MARKER_COLORS[settings.markerColorIdx].color)
		beamInst.Width0 = 0.15
		beamInst.Width1 = 0.15
		beamInst.FaceCamera = true
		beamInst.Segments = 10
		beamInst.Parent = rootPart
	end
	beamInst.Attachment0 = beamAtt0
	beamInst.Attachment1 = beamAtt1
end

