-- =============================================
--  HELPER: raised-border (classic Win95 look)
-- =============================================
-- Simulated with a UIStroke; 3-D bevel done via two thin border frames
local function applyRaisedBorder(frame)
	-- outer dark
	local s = Instance.new("UIStroke")
	s.Thickness = 2
	s.Color = C.BORDER_DARK
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = frame
	return s
end

local function makeCorner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 0)
	c.Parent = parent
	return c
end

