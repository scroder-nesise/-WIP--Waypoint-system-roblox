teleportButton.MouseButton1Click:Connect(function()
	if not selectedWaypoint or not rootPart then
		setStatus("Select a waypoint to teleport!")
		return
	end
	rootPart.CFrame = CFrame.new(selectedWaypoint.position + Vector3.new(0, 5, 0))
	local hum = character:FindFirstChildOfClass("Humanoid")
	if hum then hum:ChangeState(Enum.HumanoidStateType.RunningNoPhysics) end
	setStatus('Teleported to "' .. selectedWaypoint.name .. '"')
end)

deleteButton.MouseButton1Click:Connect(function()
	if not selectedWaypoint then
		setStatus("Select a waypoint to delete!")
		return
	end
	if selectedWaypoint.marker then selectedWaypoint.marker:Destroy() end
	for i, wp in ipairs(waypoints) do
		if wp == selectedWaypoint then table.remove(waypoints, i) break end
	end
	selectedWaypoint = nil
	refreshList()
end)

