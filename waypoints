local function addWaypoint()
	if not rootPart then return end
	if settings.maxWaypoints > 0 and #waypoints >= settings.maxWaypoints then
		setStatus("⚠ Limit reached! Max: " .. settings.maxWaypoints)
		return
	end
	local newWP = {
		name     = "Waypoint " .. (#waypoints + 1),
		position = rootPart.Position,
		marker   = nil,
		guiEntry = nil,
	}
	table.insert(waypoints, newWP)
	createMarker(newWP)
	setStatus("Added: " .. newWP.name)
	refreshList()
end

local function teleportTo(wp)
	if not wp or not rootPart then
		setStatus("Select a waypoint to teleport!")
		return
	end
	local target = wp.position + Vector3.new(0, settings.tpHeight, 0)
	if settings.smoothTp then
		local tween = TweenService:Create(rootPart, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			CFrame = CFrame.new(target)
		})
		tween:Play()
	else
		rootPart.CFrame = CFrame.new(target)
	end
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
	end
	setStatus("Teleported to: " .. wp.name)
end

