	local textBox = Instance.new("TextBox")
	textBox.Size = UDim2.new(0.9, 0, 0, 38)
	textBox.Position = UDim2.new(0.05, 0, 0.35, 0)
	textBox.Text = selectedWaypoint.name
	textBox.PlaceholderText = "Enter new name..."
	textBox.TextScaled = true
	textBox.ClearTextOnFocus = true
	textBox.Parent = renameFrame
	
	local confirm = Instance.new("TextButton")
	confirm.Size = UDim2.new(0.42, 0, 0, 32)
	confirm.Position = UDim2.new(0.06, 0, 0.72, 0)
	confirm.BackgroundColor3 = Color3.fromRGB(0, 190, 80)
	confirm.Text = "Save"
	confirm.TextColor3 = Color3.new(1, 1, 1)
	confirm.TextScaled = true
	confirm.Parent = renameFrame
	
	local cancel = Instance.new("TextButton")
	cancel.Size = UDim2.new(0.42, 0, 0, 32)
	cancel.Position = UDim2.new(0.52, 0, 0.72, 0)
	cancel.BackgroundColor3 = Color3.fromRGB(190, 40, 40)
	cancel.Text = "Cancel"
	cancel.TextColor3 = Color3.new(1, 1, 1)
	cancel.TextScaled = true
	cancel.Parent = renameFrame
	
	confirm.MouseButton1Click:Connect(function()
		if textBox.Text ~= "" then
			selectedWaypoint.name = textBox.Text
			if selectedWaypoint.marker then
				local bb = selectedWaypoint.marker:FindFirstChildOfClass("BillboardGui")
				if bb then
					local lbl = bb:FindFirstChildOfClass("TextLabel")
					if lbl then lbl.Text = selectedWaypoint.name end
				end
			end
		end
		renameFrame:Destroy()
		refreshList()
	end)
	
	cancel.MouseButton1Click:Connect(function() renameFrame:Destroy() end)
	
	textBox:CaptureFocus()
end)

-- Teleport to selected waypoint
teleportButton.MouseButton1Click:Connect(function()
	if not selectedWaypoint or not rootPart then return end
	
	local targetPos = selectedWaypoint.position + Vector3.new(0, 5, 0)
	rootPart.CFrame = CFrame.new(targetPos)
	
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
	end
end)

-- Delete selected
deleteButton.MouseButton1Click:Connect(function()
	if not selectedWaypoint then return end
	
	if selectedWaypoint.marker then
		selectedWaypoint.marker:Destroy()
	end
	
	for i, wp in ipairs(waypoints) do
		if wp == selectedWaypoint then
			table.remove(waypoints, i)
			break
		end
	end
	
	selectedWaypoint = nil
	refreshList()
end)

-- Initial refresh
refreshList()
