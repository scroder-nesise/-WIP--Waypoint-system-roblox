-- Mutually-exclusive option button group
local function optionGroup(yPos, xStart, opts, activeIdx, btnW, onSelect)
    local btns = {}
    local gap = 4
    for i, text in ipairs(opts) do
        local btn = Instance.new("TextButton")
        btn.Size             = UDim2.new(0, btnW, 0, 22)
        btn.Position         = UDim2.new(0, xStart + (i - 1) * (btnW + gap), 0, yPos)
        btn.BackgroundColor3 = (i == activeIdx) and C.SEL_BG or C.BTN_FACE
        btn.Text             = text
        btn.TextColor3       = (i == activeIdx) and Color3.new(1,1,1) or C.TEXT_DARK
        btn.TextScaled       = true
        btn.Font             = Enum.Font.Legacy
        btn.BorderSizePixel  = 0
        btn.AutoButtonColor  = false
        btn.ZIndex           = 22
        btn.Parent           = sContent
        applyRaisedBorder(btn)
        table.insert(btns, btn)
    end
    local function setActive(idx)
        for j, b in ipairs(btns) do
            b.BackgroundColor3 = (j == idx) and C.SEL_BG or C.BTN_FACE
            b.TextColor3       = (j == idx) and Color3.new(1,1,1) or C.TEXT_DARK
        end
    end
    for i, btn in ipairs(btns) do
        local ci = i
        btn.MouseButton1Click:Connect(function()
            setActive(ci)
            onSelect(ci, opts[ci])
        end)
    end
    return btns
end

-- Full-width action button
local function actionButton(yPos, text, color)
