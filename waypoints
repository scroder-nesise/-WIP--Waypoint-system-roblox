exportBtn.MouseButton1Click:Connect(function()
    if #waypoints == 0 then
        setStatus("No waypoints to export.")
        return
    end
    print("=== WAYPOINTS EXPORT (" .. #waypoints .. ") ===")
    for i, wp in ipairs(waypoints) do
        print(string.format("  %d.  %-20s  (%.1f, %.1f, %.1f)",
            i, wp.name, wp.position.X, wp.position.Y, wp.position.Z))
    end
    print("==============================================")
    setStatus("Exported " .. #waypoints .. " waypoints → Output window.")
end)

clearBtn.MouseButton1Click:Connect(function()
    for _, wp in ipairs(waypoints) do
        if wp.marker then wp.marker:Destroy() end
    end
    waypoints           = {}
    selectedWaypoint    = nil
    settingsOpen        = false
    settingsPanel.Visible = false
    setStatus("All waypoints cleared.")
    refreshList()
end)

