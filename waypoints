deleteButton.MouseButton1Click:Connect(function()
	if not selectedWaypoint then
		setStatus("Select a waypoint to delete!")
		return
	end
	local deletedName = selectedWaypoint.name
	if selectedWaypoint.marker then
		selectedWaypoint.marker:Destroy()
	end
	for i, wp in ipairs(waypoints) do
		if wp == selectedWaypoint then
			table.remove(waypoints, i)
			break
		end
	end
	selectedWaypoint = nil
	setStatus("Deleted: " .. deletedName)
	refreshList()
end)

